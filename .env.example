NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters

B2_S3_ENDPOINT=https://s3.YOUR-REGION.backblazeb2.com
B2_KEY_ID=your-b2-key-id
B2_APPLICATION_KEY=your-b2-application-key
B2_BUCKET_NAME=your-private-bucket-name

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Cloud Drive <noreply@yourcompany.com>
MAX_UPLOAD_SIZE_BYTES=262144000
DEFAULT_SOFT_DELETE_RETENTION_DAYS=30
INTERNAL_EMAIL_DOMAIN=yourcompany.com
